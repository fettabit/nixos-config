      "hands-free": "¾░éæ",
      "headset": "¾░éæ",
      "phone": "´éò",
      "phone-muted": "¯┤ù",
      "portable": "´éò",
      "car": "´å╣",
      "default": [
        "´Çğ",
        "´Ç¿"
      ]
    },
    "scroll-step": 1,
